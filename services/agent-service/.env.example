# Service Configuration
SERVICE_NAME=agent-service
SERVICE_VERSION=0.1.0
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8003

# External Services
ENVIRONMENT_API_URL=http://environment-api:8000
RAG_API_URL=http://rag-service:8001

# AWS Bedrock Configuration
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_TEMPERATURE=0.0
BEDROCK_MAX_TOKENS=4000

# AWS Credentials
# Do NOT set AWS_ACCESS_KEY_ID or AWS_SECRET_ACCESS_KEY here.
# They are injected by docker-compose from the host shell environment.
# Source scripts/aws-env.sh before running docker compose up.

# Redis Configuration
REDIS_URL=redis://redis:6379
CACHE_TTL_SECONDS=3600

# Agent Configuration
MAX_ITERATIONS=10
TOOL_TIMEOUT_SECONDS=30

# LangSmith Tracing (optional)
# Set LANGCHAIN_TRACING_V2=true to send traces to LangSmith.
# Get your API key from https://smith.langchain.com/
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=<your_langsmith_api_key>
LANGCHAIN_PROJECT=<your_project_name>

# Logging
LOG_LEVEL=INFO

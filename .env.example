POSTGRES_USER=<your_postgres_user>
POSTGRES_PASSWORD=<your_secure_password>
POSTGRES_DB=beliefcraft
POSTGRES_PORT=5432
ENVIRONMENT_DB=environment_api
RAG_DB=rag_service
QDRANT_PORT=6333
REDIS_PORT=6379

# LangSmith Tracing (optional - agent-service only)
# Set LANGCHAIN_TRACING_V2=true to send traces to LangSmith.
# Get your API key from https://smith.langchain.com/
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=<your_langsmith_api_key>
LANGCHAIN_PROJECT=<your_project_name>
